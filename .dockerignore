# ── Secrets — NEVER bake these into the image ──────────────────────────
.env
.env.*
!.env.example

# ── Development artifacts ───────────────────────────────────────────────
.git
.github
.gitignore
.pytest_cache
__pycache__
*.pyc
*.pyo
*.pyd
.Python
venv/
.venv/
uv.lock

