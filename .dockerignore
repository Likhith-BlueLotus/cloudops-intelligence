tests/
.coverage
htmlcov/
.tox/

# ── Editor / OS artifacts ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docs / notebooks ────────────────────────────────────────────────────
*.md
!README.md
docs/
notebooks/
