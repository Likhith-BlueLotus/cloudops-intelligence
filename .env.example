# CloudOps Intelligence Environment — credential template
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
#
# Required per hackathon spec:

# LLM API base URL (OpenAI-compatible)
API_BASE_URL=https://api.openai.com/v1

# Model identifier
MODEL_NAME=gpt-4o-mini

# Your API key — works with OpenAI keys (sk-...) or HF tokens (hf_...)
HF_TOKEN=YOUR_API_KEY_HERE

# Environment server URL (change to http://localhost:7860 for local dev)
OPENENV_ENDPOINT=https://le0atis-cloudops-intelligence.hf.space
